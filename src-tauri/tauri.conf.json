{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "POS Sistema",
  "version": "1.0.0",
  "identifier": "com.domercd.pos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "VITE_API_URL=https://api.domercd.com npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "POS Sistema",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
